{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{- /* Override of Hugo's default sitemap. The only change: list pages (home,
      /docs/, /changelog/) inherit the newest lastmod among their descendants
      instead of the git date on their own _index.md. Without it the hub pages stood
      as older than the docs they actually list – Google recommends that lastmod
      reflects the most recent significant change. Leaf pages have no
      RegularPagesRecursive, so $lastmod remains their own .Lastmod. */ -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- range .Data.Pages }}
  {{- if .Permalink }}
  {{- $lastmod := .Lastmod }}
  {{- range .RegularPagesRecursive }}{{ if .Lastmod.After $lastmod }}{{ $lastmod = .Lastmod }}{{ end }}{{ end }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not $lastmod.IsZero }}
    <lastmod>{{ $lastmod.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</lastmod>
    {{- end }}
    {{- with .Sitemap.ChangeFreq }}
    <changefreq>{{ . }}</changefreq>
    {{- end }}
    {{- if ge .Sitemap.Priority 0.0 }}
    <priority>{{ .Sitemap.Priority }}</priority>
    {{- end }}
  </url>
  {{- end }}
  {{- end }}
</urlset>
